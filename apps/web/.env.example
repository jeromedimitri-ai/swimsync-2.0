# ============================================
# SWIMSYNC 2.0 - ENVIRONNEMENT VARIABLES
# ============================================

# Database
# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@localhost:5432/swimsync?schema=public"

# NextAuth.js
# Générer avec: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email (optionnel - pour les notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@swimsync.fr"

# Application
NEXT_PUBLIC_APP_NAME="SwimSync 2.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# CN Avignon - Informations
NEXT_PUBLIC_CLUB_NAME="Centre de Natation Avignon"
NEXT_PUBLIC_CLUB_EMAIL="direction@cn-avignon.fr"
NEXT_PUBLIC_CLUB_PHONE="+33 4 90 XX XX XX"

# Prisma
DIRECT_URL="postgresql://postgres:password@localhost:5432/swimsync?schema=public"

# Sentry (optionnel - monitoring erreurs)
SENTRY_DSN=""

# Analytics (optionnel)
NEXT_PUBLIC_GA_ID=""

# Mode
NODE_ENV="development"
