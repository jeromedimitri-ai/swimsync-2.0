// SwimSync 2.0 - Prisma Schema
// Base de données pour la gestion du planning des piscines CN Avignon

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODÈLE: Coach
// ============================================
model Coach {
  id        String   @id @default(cuid())
  nom       String
  prenom    String
  email     String   @unique
  telephone String?
  diplomes  String[] // Array des diplômes (BEESAN, BPJEPS, etc.)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creneaux      Creneau[]
  remplacements Remplacement[]
  absences      Absence[]
  paies         Paie[]

  @@index([email])
  @@index([actif])
}

// ============================================
// MODÈLE: Groupe
// ============================================
model Groupe {
  id          String @id @default(cuid())
  nom         String
  niveau      String // EN1, EN2, EN3, EN4, Junior, Senior
  ageMin      Int
  ageMax      Int
  description String?
  actif       Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  creneaux Creneau[]

  @@index([niveau])
  @@index([actif])
}

// ============================================
// MODÈLE: Bassin (Pool)
// ============================================
model Bassin {
  id         String  @id @default(cuid())
  nom        String  @unique
  adresse    String
  capacite   Int
  longueur   Int     // 25m ou 50m
  actif      Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  creneaux Creneau[]

  @@index([nom])
  @@index([actif])
}

// ============================================
// MODÈLE: Créneau
// ============================================
model Creneau {
  id            String   @id @default(cuid())
  jour          String   // LUNDI, MARDI, etc.
  heureDebut    String   // "17:45"
  heureFin      String   // "19:00"
  recurrent     Boolean  @default(true)
  dateDebut     DateTime?
  dateFin       DateTime?
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  coachId   String
  coach     Coach   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  groupeId  String
  groupe    Groupe  @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  bassinId  String
  bassin    Bassin  @relation(fields: [bassinId], references: [id], onDelete: Cascade)

  absences      Absence[]
  remplacements Remplacement[]

  @@index([jour])
  @@index([coachId])
  @@index([groupeId])
  @@index([bassinId])
  @@index([actif])
}

// ============================================
// MODÈLE: Absence
// ============================================
model Absence {
  id          String   @id @default(cuid())
  dateDebut   DateTime
  dateFin     DateTime
  motif       String?
  type        String   // CONGES, MALADIE, FORMATION, AUTRE
  statut      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  creneauId   String?
  creneau     Creneau? @relation(fields: [creneauId], references: [id], onDelete: SetNull)

  remplacement Remplacement?

  @@index([coachId])
  @@index([dateDebut])
  @@index([statut])
}

// ============================================
// MODÈLE: Remplacement
// ============================================
model Remplacement {
  id                String   @id @default(cuid())
  date              DateTime
  statut            String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  commentaire       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  absenceId         String   @unique
  absence           Absence  @relation(fields: [absenceId], references: [id], onDelete: Cascade)
  coachRemplacantId String
  coachRemplacant   Coach    @relation(fields: [coachRemplacantId], references: [id], onDelete: Cascade)
  creneauId         String
  creneau           Creneau  @relation(fields: [creneauId], references: [id], onDelete: Cascade)

  @@index([absenceId])
  @@index([coachRemplacantId])
  @@index([date])
  @@index([statut])
}

// ============================================
// MODÈLE: Paie
// ============================================
model Paie {
  id              String   @id @default(cuid())
  mois            Int      // 1-12
  annee           Int
  heuresPrevues   Float
  heuresRealisees Float
  tauxHoraire     Float
  montantBrut     Float
  montantNet      Float?
  statut          String   @default("DRAFT") // DRAFT, SUBMITTED, PAID
  datePaiement    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  coachId String
  coach   Coach  @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([coachId, mois, annee])
  @@index([coachId])
  @@index([mois, annee])
  @@index([statut])
}

// ============================================
// MODÈLE: JourFerie (Vacances Zone B)
// ============================================
model JourFerie {
  id          String   @id @default(cuid())
  nom         String
  dateDebut   DateTime
  dateFin     DateTime
  zone        String   @default("B") // Zone B pour Avignon
  type        String   // VACANCES_SCOLAIRES, JOUR_FERIE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([dateDebut])
  @@index([zone])
  @@index([type])
}

// ============================================
// MODÈLE: User (NextAuth)
// ============================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // USER, ADMIN, COACH
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
